									layoutpolicy_horizontal = expanding
									using = Background_DropDown
									margin = { 4 4 }
									spacing = 1
									leo_mvd_button_dropdown = {
										layoutpolicy_horizontal = expanding
										size = { -1 30 }
										onclick = "[GetScriptedGui('leo_mvd_focus_r1_n1').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
										onclick = "[GetScriptedGui('leo_mvd_set_dir_1').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
										onclick = "[GetVariableSystem.Set( 'leo_mvd_dd', 'none' )]"
										text = "leo_mvd_ui_dir_1"
									}
									leo_mvd_button_dropdown = {
										layoutpolicy_horizontal = expanding
										size = { -1 30 }
										onclick = "[GetScriptedGui('leo_mvd_focus_r1_n1').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
										onclick = "[GetScriptedGui('leo_mvd_set_dir_2').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
										onclick = "[GetVariableSystem.Set( 'leo_mvd_dd', 'none' )]"
