								onclick = "[GetScriptedGui('leo_mvd_set_kind_2').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
								tooltip = "leo_mvd_ui_kind_2_tt"
								blockoverride "radio" {
