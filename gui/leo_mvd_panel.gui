										onclick = "[GetScriptedGui('leo_mvd_remove_qpriority_3').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
										tooltip = "leo_mvd_ui_remove_qpriority_tt"
									}
								}
							}
						}
					}
					
					### Start a nomad waterfall, when there is not one yet.
					hbox = {
						visible = "[And( HasDlcFeature( 'khans_of_the_steppe' ), And( GreaterThanOrEqualTo_CFixedPoint( GetPlayer.MakeScope.Var('leo_mvd_rule_count').GetValue, '(CFixedPoint)1' ), Not( GreaterThanOrEqualTo_CFixedPoint( GetPlayer.MakeScope.Var('leo_mvd_qrule_count').GetValue, '(CFixedPoint)1' ) ) ) )]"
						layoutpolicy_horizontal = expanding
						margin = { 6 4 }
						
						button_standard = {
							layoutpolicy_horizontal = expanding
							text = "leo_mvd_ui_add_priority"
							onclick = "[GetScriptedGui('leo_mvd_add_qpriority').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
							tooltip = "leo_mvd_ui_nomads_empty_tt"
						}
					}
				}
			}
		}

		### Action buttons - fixed footer, expanding so they split the row.
		hbox = {
			layoutpolicy_horizontal = expanding
			margin_top = 10
			margin_right = 16
			margin_bottom = 14
			margin_left = 16
			spacing = 6

			button_standard = {
				layoutpolicy_horizontal = expanding
				text = "leo_mvd_ui_apply"
				onclick = "[GetScriptedGui('leo_mvd_apply_now').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
				enabled = "[GetScriptedGui('leo_mvd_apply_now').IsValid( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
				tooltip = "leo_mvd_ui_apply_tt"
			}

			button_standard = {
				layoutpolicy_horizontal = expanding
				text = "leo_mvd_ui_remove_all"
				onclick = "[GetScriptedGui('leo_mvd_remove_all').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
				tooltip = "leo_mvd_ui_remove_all_tt"
			}
		}
	}
}
