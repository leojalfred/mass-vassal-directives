								}
							}
							button_radio_label = {
								layoutpolicy_horizontal = expanding
								onclick = "[GetScriptedGui('leo_mvd_focus_r1_n1').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
								onclick = "[GetScriptedGui('leo_mvd_set_kind_1').Execute( GuiScope.SetRoot( GetPlayer.MakeScope ).End )]"
								tooltip = "leo_mvd_ui_kind_1_tt"
								blockoverride "radio" {
